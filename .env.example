# Resend API key for email notifications (https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# PostgreSQL database URL
DATABASE_URL=postgres://user:password@your-database-host:5432/dbname?sslmode=require

# Optional aliases for environments that still inject these names
POSTGRES_URL=postgres://user:password@your-database-host:5432/dbname?sslmode=require
PRISMA_DATABASE_URL=postgres://user:password@your-database-host:5432/dbname?sslmode=require

# Public site URL (for metadata, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Catalog data source. Use `database` with a real DB URL, or `seed` for local fallback data.
CATALOG_DATA_SOURCE=seed

# Admin panel
