# Resend API key for email notifications (https://resend.com)
RESEND_API_KEY=re_your_api_key_here

# PostgreSQL database URL (Prisma)
PRISMA_DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Same URL for direct Prisma Client access (if used)
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Public site URL (for metadata, OG images, etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
